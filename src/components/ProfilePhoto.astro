---
import Pills from './Pills.astro';
import * as config from '../config.md';

const profilePhoto = config.frontmatter.profilePhoto || '/images/me_pixel.png';
---

<div class="profile-photo-container">
	<div class="photo-wrapper">
		<img src={profilePhoto} alt="Profile Photo" class="profile-photo" />
		<Pills />
	</div>
</div>

<style>
	.profile-photo-container {
		display: flex;
		justify-content: center;
		align-items: center;
		margin-bottom: 1.5rem;
		width: 100%;
	}

	.photo-wrapper {
		position: relative;
		display: inline-flex;
	}

	.profile-photo {
		width: 150px;
		height: 150px;
		object-fit: cover;
		border-radius: 50%;
		border: 4px solid var(--color-primary-glow);
		box-shadow: 0 4px 24px 0 rgba(127, 124, 236, 0.25);
		background: var(--color-bg-dark);
		transition: transform 0.3s;
	}

	.profile-photo:hover {
		transform: scale(1.06) rotate(-2deg);
		box-shadow: 0 8px 32px 0 var(--color-primary-glow);
	}

	@media (max-width: 480px) {
		.profile-photo {
			width: 100px;
			height: 100px;
		}
	}
</style>
