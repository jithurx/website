---
---

<div class="profile-photo-container">
	<div class="photo-wrapper">
		<img src="/images/me_pixel.png" alt="Profile Photo" class="profile-photo" />
		<div class="blog-pill-wrapper">
			<a href="https://blogs.jithurx.dev" target="_blank" rel="noopener noreferrer" class="blog-pill">
				Blogs <i class="fas fa-arrow-right"></i>
			</a>
		</div>
	</div>
</div>

<style>
	.profile-photo-container {
		display: flex;
		justify-content: center;
		align-items: center;
		margin-bottom: 1.5rem;
		width: 100%;
	}

	.photo-wrapper {
		position: relative;
		display: inline-flex;
	}

	.profile-photo {
		width: 150px;
		height: 150px;
		object-fit: cover;
		border-radius: 50%;
		border: 4px solid var(--color-primary-glow);
		box-shadow: 0 4px 24px 0 rgba(127, 124, 236, 0.25);
		background: var(--color-bg-dark);
		transition: transform 0.3s;
	}

	.profile-photo:hover {
		transform: scale(1.06) rotate(-2deg);
		box-shadow: 0 8px 32px 0 var(--color-primary-glow);
	}

	.blog-pill-wrapper {
		position: absolute;
		left: 100%;
		margin-left: 50px;
		top: 15px;
		animation: float 4s ease-in-out infinite;
		z-index: 2;
	}

	@keyframes float {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	.blog-pill {
		background: var(--color-secondary-glow);
		color: var(--color-bg-dark);
		padding: 0.5rem 1.2rem;
		border-radius: 2rem;
		font-weight: 700;
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		box-shadow: 0 4px 15px rgba(212, 255, 58, 0.3);
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s;
	}

	.blog-pill:hover {
		transform: scale(1.1);
		box-shadow: 0 6px 20px rgba(212, 255, 58, 0.6);
	}

	@media (max-width: 480px) {
		.profile-photo {
			width: 100px;
			height: 100px;
		}

		.blog-pill-wrapper {
			left: 100%;
			margin-left: 25px;
		}

		.blog-pill {
			font-size: 0.9rem;
			padding: 0.4rem 0.8rem;
		}
	}
</style>
