<style>
	/* --- Social Links Styles --- */
	.codeberg-icon {
		width: 1em;
		height: 1em;
		fill: currentColor;
		vertical-align: -0.125em;
	}

	.social-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1.5rem;
	}

	.social-links a, .git-icon {
		color: var(--color-text-light);
		font-size: 2rem;
		text-decoration: none;
		border: 2px solid transparent;
		padding: 0.5rem;
		border-radius: 50%;
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		display: inline-block;
		line-height: 1;
		cursor: pointer;
	}

	.social-links a:hover {
		transform: scale(1.2);
		border-color: currentColor;
		box-shadow: 0 0 15px currentColor;
	}

	.git-dropdown {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.git-dropdown-content {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) scale(0.5);
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		background: var(--color-bg-dark);
		border: 1px solid var(--color-border-light);
		padding: 0.5rem;
		border-radius: 2rem;
		opacity: 0;
		visibility: hidden;
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		box-shadow: 0 5px 15px rgba(0,0,0,0.5);
		z-index: 10;
		pointer-events: none;
	}

	.git-dropdown:hover .git-dropdown-content {
		opacity: 1;
		visibility: visible;
		transform: translate(-50%, -50%) scale(1);
		pointer-events: auto;
	}

	.git-dropdown-content a {
		font-size: 1.5rem;
		padding: 0.4rem;
	}

	.git-dropdown:hover .git-icon {
		opacity: 0;
		transform: scale(0.5);
	}

	.social-links a.github:hover {
		color: #d6eac1;
	}

	.social-links a.gitlab:hover {
		color: #fc6d26;
	}

	.social-links a.codeberg:hover {
		color: #2185d0;
	}

	.social-links a.linkedin:hover {
		color: #3399ff;
	}

	.social-links a.instagram:hover {
		color: #e770c3;
	}

	.social-links a.spotify:hover {
		color: #24d02d;
	}

	.social-links a.pinterest:hover {
		color: #ff3333;
	}

	@media (max-width: 768px) {
		.social-links {
			gap: 1rem;
		}

		.social-links a, .git-icon {
			font-size: 1.8rem;
			padding: 0.4rem;
		}

		.git-dropdown-content a {
			font-size: 1.4rem;
			padding: 0.3rem;
		}
	}

	@media (max-width: 480px) {
		.social-links a, .git-icon {
			font-size: 1.6rem;
		}

		.git-dropdown-content a {
			font-size: 1.2rem;
		}
	}
</style>
