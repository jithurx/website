# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Security - REQUIRED: Change these in production
PORTAL_SECRET=your-32-character-random-secret-here
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here
SETUP_TOKEN=setup-token-for-first-admin-only

# Database
DATABASE_PATH=/data/portal.db

# Redis (optional, for distributed sessions)
# REDIS_URL=redis://redis:6379

# Vaultwarden Integration (optional)
VAULTWARDEN_URL=http://vaultwarden:80
VAULTWARDEN_API_KEY=internal-api-key

# Logging
LOG_LEVEL=info
LOG_FILE=/data/logs/portal.log

# Two-Factor Authentication
TOTP_WINDOW=2

# File Upload
MAX_FILE_SIZE_MB=500
UPLOAD_DIR=/data/uploads

# CORS
CORS_ORIGIN=https://example.com

# Generate secrets with:
# openssl rand -hex 16  (for PORTAL_SECRET)
# openssl rand -base64 32  (for ENCRYPTION_KEY)
# openssl rand -hex 32  (for JWT_SECRET)
